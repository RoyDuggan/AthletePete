# Copy to `.env` and fill in. Used by docker compose.

# --- Database ---
POSTGRES_USER=vpete
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=virtualpete

# --- Backend ---
# Anthropic key for the AI coaching summaries.
ANTHROPIC_API_KEY=sk-ant-...
# Long random string used to sign auth tokens (Phase 1).
JWT_SECRET=change-me-to-a-long-random-string

# --- Stripe billing (Phase 4) ---
# Leave blank to keep billing disabled. Use TEST keys until you go live.
# Secret key: Stripe Dashboard → Developers → API keys (sk_test_... / sk_live_...).
STRIPE_SECRET_KEY=
# Webhook signing secret for the /api/billing/webhook endpoint
# (Dashboard → Developers → Webhooks, or `stripe listen` for local dev): whsec_...
STRIPE_WEBHOOK_SECRET=
# Recurring Price IDs (Dashboard → Product catalogue → your price): price_...
STRIPE_PRICE_DRIVER=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_COACH=

# --- Email (Postmark) ---
# Leave blank to keep email disabled (messages are logged to the server console
# instead). Server API Token: Postmark → your Server → API Tokens.
POSTMARK_SERVER_TOKEN=
# Verified sender address (Postmark sender signature / verified domain).
EMAIL_FROM=no-reply@virtualpete.co.uk
# Public base URL used to build links in emails (falls back to the request origin).
APP_URL=https://virtualpete.co.uk

# --- Backups ---
# Cron schedule for the nightly backup (default 03:00) and how many days of
# archives to keep in ./backups.
BACKUP_CRON=0 3 * * *
BACKUP_KEEP_DAYS=14

# --- Web / Caddy ---
# Local HTTP: leave as ":80" and reach the app on http://localhost:8080
# Production: set to your domain (e.g. app.example.com) for automatic HTTPS,
# and set HTTP_PORT=80 / HTTPS_PORT=443 below.
SITE_ADDRESS=:80
HTTP_PORT=8080
HTTPS_PORT=8443
